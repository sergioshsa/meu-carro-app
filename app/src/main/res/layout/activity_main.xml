<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0E0E0E">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ============ PÁGINA MODO ============ -->
        <ScrollView android:id="@+id/pageModo" android:layout_width="match_parent"
            android:layout_height="match_parent" android:fillViewport="true">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp" android:gravity="center_horizontal">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="MEU CARRO" android:textColor="#C9A043" android:textSize="24sp"
                    android:textStyle="bold" android:layout_marginBottom="16dp" />

                <TextView android:id="@+id/btnModeCircle" android:layout_width="200dp"
                    android:layout_height="200dp" android:background="@drawable/circle_mode"
                    android:gravity="center" android:text="PESSOAL" android:textColor="#0E0E0E"
                    android:textSize="26sp" android:textStyle="bold" android:clickable="true"
                    android:focusable="true" android:backgroundTint="#C9A043"
                    android:layout_marginBottom="10dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="(toque no círculo para alternar Uber/Pessoal)"
                    android:textColor="#888888" android:textSize="11sp" android:layout_marginBottom="16dp" />

                <TextView android:id="@+id/tvStatus" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="○ Parado" android:textColor="#FFFFFF"
                    android:textSize="15sp" android:textStyle="bold" android:padding="12dp"
                    android:background="#1C1C1C" android:layout_marginBottom="10dp" />

                <TextView android:id="@+id/tvUsageWarn" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="" android:textColor="#E0A030"
                    android:textSize="12sp" android:layout_marginBottom="12dp" />

                <Button android:id="@+id/btnAuto" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="ATIVAR MODO AUTOMÁTICO (Uber Driver)"
                    android:textColor="#0E0E0E" android:backgroundTint="#C9A043" android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <Button android:id="@+id/btnStop" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="PARAR REGISTRO"
                    android:textColor="#FFFFFF" android:backgroundTint="#B03030" android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <Button android:id="@+id/btnUsage" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Conceder acesso de uso (1x)"
                    android:textColor="#FFFFFF" android:backgroundTint="#2A2A2A" android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <Button android:id="@+id/btnTest" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="TESTAR DETECÇÃO AGORA"
                    android:textColor="#0E0E0E" android:backgroundTint="#E0A030" android:textStyle="bold"
                    android:textSize="12sp" />
            </LinearLayout>
        </ScrollView>

        <!-- ============ PÁGINA MESES ============ -->
        <ScrollView android:id="@+id/pageMeses" android:layout_width="match_parent"
            android:layout_height="match_parent" android:fillViewport="true" android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <Button android:id="@+id/btnPrevMonth" android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="◀ Mês anterior"
                        android:textColor="#FFFFFF" android:backgroundTint="#2A2A2A" android:textSize="12sp"
                        android:layout_marginEnd="6dp" />
                    <Button android:id="@+id/btnNextMonth" android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="Próximo ▶"
                        android:textColor="#FFFFFF" android:backgroundTint="#2A2A2A" android:textSize="12sp" />
                </LinearLayout>

                <TextView android:id="@+id/tvMonth" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="MÊS" android:textColor="#FFFFFF"
                    android:textSize="15sp" android:lineSpacingExtra="4dp" android:padding="14dp"
                    android:background="#14261B" android:layout_marginBottom="14dp" />

                <TextView android:id="@+id/tvDest" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="DESTINOS" android:textColor="#FFFFFF"
                    android:textSize="15sp" android:lineSpacingExtra="4dp" android:padding="14dp"
                    android:background="#1C1C1C" android:layout_marginBottom="8dp" />

                <Button android:id="@+id/btnRenameDest" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Renomear um destino"
                    android:textColor="#FFFFFF" android:backgroundTint="#2A2A2A" android:textSize="12sp"
                    android:layout_marginBottom="14dp" />

                <TextView android:id="@+id/tvTotals" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="TOTAL GERAL" android:textColor="#FFFFFF"
                    android:textSize="15sp" android:lineSpacingExtra="4dp" android:padding="14dp"
                    android:background="#1C1C1C" android:layout_marginBottom="14dp" />

                <Button android:id="@+id/btnReset" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Zerar totais e meses"
                    android:textColor="#AAAAAA" android:backgroundTint="#2A2A2A" android:textSize="12sp" />
            </LinearLayout>
        </ScrollView>

        <!-- ============ PÁGINA TANQUE ============ -->
        <ScrollView android:id="@+id/pageTanque" android:layout_width="match_parent"
            android:layout_height="match_parent" android:fillViewport="true" android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:id="@+id/tvTank" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="TANQUE ATUAL" android:textColor="#FFFFFF"
                    android:textSize="15sp" android:lineSpacingExtra="4dp" android:padding="14dp"
                    android:background="#14261B" android:layout_marginBottom="12dp" />

                <Button android:id="@+id/btnAbastecer" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="REGISTRAR ABASTECIMENTO"
                    android:textColor="#0E0E0E" android:backgroundTint="#C9A043" android:textStyle="bold"
                    android:layout_marginBottom="20dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CALCULADORA DO TANQUE" android:textColor="#C9A043" android:textSize="15sp"
                    android:textStyle="bold" android:layout_marginBottom="2dp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Lance litros e km rodados; divide entre Pessoal e Uber pela proporção."
                    android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginBottom="8dp" />

                <EditText android:id="@+id/etCalcLiters" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Litros do tanque (ex: 40)"
                    android:textColorHint="#777777" android:textColor="#FFFFFF"
                    android:inputType="numberDecimal" android:backgroundTint="#C9A043"
                    android:layout_marginBottom="8dp" />
                <EditText android:id="@+id/etCalcKm" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="KM rodados com o tanque (ex: 520)"
                    android:textColorHint="#777777" android:textColor="#FFFFFF"
                    android:inputType="numberDecimal" android:backgroundTint="#C9A043"
                    android:layout_marginBottom="10dp" />
                <Button android:id="@+id/btnCalc" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="CALCULAR DIVISÃO"
                    android:textColor="#FFFFFF" android:backgroundTint="#1A6B2A" android:textStyle="bold"
                    android:layout_marginBottom="10dp" />
                <TextView android:id="@+id/tvCalcResult" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="" android:textColor="#FFFFFF"
                    android:textSize="15sp" android:lineSpacingExtra="4dp" android:padding="14dp"
                    android:background="#1C1C1C" />
            </LinearLayout>
        </ScrollView>

        <!-- ============ PÁGINA NUVEM ============ -->
        <ScrollView android:id="@+id/pageNuvem" android:layout_width="match_parent"
            android:layout_height="match_parent" android:fillViewport="true" android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SINCRONIZAÇÃO NA NUVEM" android:textColor="#C9A043" android:textSize="15sp"
                    android:textStyle="bold" android:layout_marginBottom="2dp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Crie um código secreto. Envia sozinho ao sair do app. Em outro celular, use o mesmo código e toque em Baixar."
                    android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginBottom="8dp" />

                <EditText android:id="@+id/etSyncCode" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Código (ex: sergio-2026)"
                    android:textColorHint="#777777" android:textColor="#FFFFFF"
                    android:inputType="textNoSuggestions" android:backgroundTint="#C9A043"
                    android:layout_marginBottom="8dp" />
                <Button android:id="@+id/btnSaveSync" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="SALVAR CÓDIGO"
                    android:textColor="#0E0E0E" android:backgroundTint="#C9A043" android:textStyle="bold"
                    android:layout_marginBottom="8dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <Button android:id="@+id/btnPush" android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="ENVIAR AGORA"
                        android:textColor="#FFFFFF" android:backgroundTint="#1A6B2A" android:textStyle="bold"
                        android:textSize="12sp" android:layout_marginEnd="6dp" />
                    <Button android:id="@+id/btnPull" android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="BAIXAR (RESTAURAR)"
                        android:textColor="#FFFFFF" android:backgroundTint="#1A5276" android:textStyle="bold"
                        android:textSize="12sp" />
                </LinearLayout>
                <TextView android:id="@+id/tvSyncStatus" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="" android:textColor="#AAAAAA"
                    android:textSize="12sp" android:padding="10dp" android:background="#14261B"
                    android:layout_marginBottom="20dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="BACKUP EM ARQUIVO" android:textColor="#C9A043" android:textSize="15sp"
                    android:textStyle="bold" android:layout_marginBottom="8dp" />
                <Button android:id="@+id/btnExport" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="EXPORTAR BACKUP (arquivo)"
                    android:textColor="#0E0E0E" android:backgroundTint="#C9A043" android:textStyle="bold"
                    android:layout_marginBottom="8dp" />
                <Button android:id="@+id/btnImport" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="IMPORTAR BACKUP (restaurar)"
                    android:textColor="#FFFFFF" android:backgroundTint="#1A6B2A" android:textStyle="bold" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#161616"
        app:elevation="8dp"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="#C9A043"
        app:itemTextColor="#C9A043" />

</LinearLayout>
