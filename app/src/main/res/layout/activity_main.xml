<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0E0E0E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MEU CARRO"
            android:textColor="#C9A043"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registro de KM: Pessoal x Uber"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginBottom="18dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="○ Parado"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="14dp"
            android:background="#1C1C1C"
            android:layout_marginBottom="18dp" />

        <Button
            android:id="@+id/btnPessoal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INICIAR MODO PESSOAL"
            android:textColor="#0E0E0E"
            android:backgroundTint="#C9A043"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnUber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INICIAR MODO UBER"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A6B2A"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PARAR REGISTRO"
            android:textColor="#FFFFFF"
            android:backgroundTint="#B03030"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvTotals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TOTAL GERAL"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:padding="14dp"
            android:background="#1C1C1C"
            android:layout_marginBottom="14dp" />

        <TextView
            android:id="@+id/tvTank"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TANQUE ATUAL"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:padding="14dp"
            android:background="#14261B"
            android:layout_marginBottom="14dp" />

        <Button
            android:id="@+id/btnAbastecer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="REGISTRAR ABASTECIMENTO (encheu o tanque)"
            android:textColor="#0E0E0E"
            android:backgroundTint="#C9A043"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Zerar totais gerais"
            android:textColor="#AAAAAA"
            android:backgroundTint="#2A2A2A"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>
