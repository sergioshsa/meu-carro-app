<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0E0E0E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="MEU CARRO" android:textColor="#C9A043" android:textSize="26sp"
            android:textStyle="bold" android:layout_marginBottom="2dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Registro de KM: Pessoal x Uber (automático)" android:textColor="#AAAAAA"
            android:textSize="13sp" android:layout_marginBottom="16dp" />

        <TextView android:id="@+id/tvStatus" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="○ Parado"
            android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"
            android:padding="14dp" android:background="#1C1C1C" android:layout_marginBottom="12dp" />

        <TextView android:id="@+id/tvUsageWarn" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="" android:textColor="#E0A030"
            android:textSize="12sp" android:layout_marginBottom="14dp" />

        <Button android:id="@+id/btnAuto" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="ATIVAR MODO AUTOMÁTICO (Uber Driver)"
            android:textColor="#0E0E0E" android:backgroundTint="#C9A043" android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <Button android:id="@+id/btnStop" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="PARAR REGISTRO"
            android:textColor="#FFFFFF" android:backgroundTint="#B03030" android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <Button android:id="@+id/btnUsage" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="Conceder acesso de uso (necessário 1x)"
            android:textColor="#FFFFFF" android:backgroundTint="#2A2A2A" android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <Button android:id="@+id/btnTest" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="TESTAR DETECÇÃO AGORA"
            android:textColor="#0E0E0E" android:backgroundTint="#E0A030" android:textStyle="bold"
            android:textSize="13sp" android:layout_marginBottom="20dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <Button android:id="@+id/btnPrevMonth" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="◀ Mês anterior"
                android:textColor="#FFFFFF" android:backgroundTint="#2A2A2A" android:textSize="12sp"
                android:layout_marginEnd="6dp" />
            <Button android:id="@+id/btnNextMonth" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="Próximo ▶"
                android:textColor="#FFFFFF" android:backgroundTint="#2A2A2A" android:textSize="12sp" />
        </LinearLayout>

        <TextView android:id="@+id/tvMonth" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="MÊS ATUAL" android:textColor="#FFFFFF"
            android:textSize="15sp" android:lineSpacingExtra="4dp" android:padding="14dp"
            android:background="#14261B" android:layout_marginBottom="14dp" />

        <TextView android:id="@+id/tvTotals" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="TOTAL GERAL" android:textColor="#FFFFFF"
            android:textSize="15sp" android:lineSpacingExtra="4dp" android:padding="14dp"
            android:background="#1C1C1C" android:layout_marginBottom="14dp" />

        <TextView android:id="@+id/tvTank" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="TANQUE ATUAL" android:textColor="#FFFFFF"
            android:textSize="15sp" android:lineSpacingExtra="4dp" android:padding="14dp"
            android:background="#14261B" android:layout_marginBottom="12dp" />

        <Button android:id="@+id/btnAbastecer" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="REGISTRAR ABASTECIMENTO (encheu o tanque)"
            android:textColor="#0E0E0E" android:backgroundTint="#C9A043" android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="CALCULADORA DO TANQUE" android:textColor="#C9A043" android:textSize="15sp"
            android:textStyle="bold" android:layout_marginBottom="2dp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Lance os litros e os km rodados; o app calcula o consumo e divide entre Pessoal e Uber pela proporção rastreada."
            android:textColor="#AAAAAA" android:textSize="12sp" android:layout_marginBottom="8dp" />

        <EditText android:id="@+id/etCalcLiters" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Litros do tanque (ex: 40)"
            android:textColorHint="#777777" android:textColor="#FFFFFF"
            android:inputType="numberDecimal" android:backgroundTint="#C9A043"
            android:layout_marginBottom="8dp" />

        <EditText android:id="@+id/etCalcKm" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="KM rodados com o tanque (ex: 520)"
            android:textColorHint="#777777" android:textColor="#FFFFFF"
            android:inputType="numberDecimal" android:backgroundTint="#C9A043"
            android:layout_marginBottom="10dp" />

        <Button android:id="@+id/btnCalc" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="CALCULAR DIVISÃO"
            android:textColor="#FFFFFF" android:backgroundTint="#1A6B2A" android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView android:id="@+id/tvCalcResult" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="" android:textColor="#FFFFFF"
            android:textSize="15sp" android:lineSpacingExtra="4dp" android:padding="14dp"
            android:background="#1C1C1C" android:layout_marginBottom="20dp" />

        <Button android:id="@+id/btnReset" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="Zerar totais e meses"
            android:textColor="#AAAAAA" android:backgroundTint="#2A2A2A" android:textSize="13sp" />

    </LinearLayout>
</ScrollView>
